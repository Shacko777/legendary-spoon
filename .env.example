# Copy this file to .env and fill in your actual credentials
# NEVER commit the real .env file to version control

# ============================================
# BYBIT API CREDENTIALS (REQUIRED)
# ============================================
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# ============================================
# TELEGRAM NOTIFICATIONS (OPTIONAL)
# ============================================
# Leave empty to disable Telegram notifications
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ============================================
# TRADING PARAMETERS
# ============================================
# Trading pair on BYBIT (e.g., BTCUSDT, ETHUSDT)
TRADING_PAIR=BTCUSDT

# Timeframe in minutes (15, 30, 60, 240, etc.)
TIMEFRAME=15

# Leverage multiplier (1 = no leverage, use cautiously)
LEVERAGE=1

# Position size in USDT per trade
POSITION_SIZE=1

# Risk percentage of total account balance per trade
RISK_PERCENTAGE=1

# ============================================
# FILTER SETTINGS (true = enabled, false = disabled)
# ============================================
ENABLE_RSI_FILTER=true
ENABLE_BOLLINGER_FILTER=true
ENABLE_ATR_FILTER=true
ENABLE_VOLUME_FILTER=true
ENABLE_TREND_STRENGTH_FILTER=true

# ============================================
# BOT BEHAVIOR
# ============================================
# Enable dry-run mode (signals only, no real trades)
DRY_RUN=false

# Enable verbose logging
VERBOSE=true

# Dashboard port
DASHBOARD_PORT=5000
